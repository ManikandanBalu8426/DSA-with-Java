/**
 * Problem: Min and Max in Array
 * Platform: GeeksforGeeks
 * Topic: Arrays
 * Day: 3
 *
 * Approach:
 * - Initialize both `min` and `max` with the first element of the array.
 * - Traverse the array once.
 * - If the current element is smaller than `min`, update `min`.
 * - Otherwise, if the current element is greater than `max`, update `max`.
 * - Store `min` and `max` in an ArrayList and return it.
 *
 * Example:
 * Input:  [1, 4, 3, 5, 8, 6]
 * Output: [1, 8]
 *
 * Time Complexity: O(n)
 * Auxiliary Space: O(1)
 */

import java.util.ArrayList;

class Solution {
    public ArrayList<Integer> getMinMax(int[] arr) {
        int min = arr[0];
        int max = arr[0];

        ArrayList<Integer> result = new ArrayList<>();

        for (int i : arr) {
            if (i < min)
                min = i;
            else if (i > max)
                max = i;
        }

        result.add(min);
        result.add(max);

        return result;
    }
}
