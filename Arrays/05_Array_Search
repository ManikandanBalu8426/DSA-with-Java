/**
 * Problem: Array Search
 * Platform: GeeksforGeeks
 * Topic: Arrays
 * Day: 5
 *
 * Approach:
 * - Traverse the array from left to right.
 * - Compare each element with the target value `x`.
 * - If a match is found, return its index immediately.
 * - If the traversal completes without finding `x`, return -1.
 *
 * Example:
 * Input:  arr = [1, 2, 3, 4], x = 3
 * Output: 2
 *
 * Time Complexity:
 * - Best Case: O(1)
 * - Average Case: O(n)
 * - Worst Case: O(n)
 *
 * Auxiliary Space: O(1)
 */

class Solution {
    public int search(int arr[], int x) {
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == x)
                return i;
        }
        return -1;
    }
}
