/**
 * Problem: Count Digits That Divide
 * Platform: GeeksforGeeks
 * Difficulty: Easy
 * Topic: Math
 *
 * Approach:
 * - Store the original number.
 * - Extract each digit using modulo (% 10).
 * - Ignore the digit if it is 0.
 * - If the original number is divisible by the digit,
 *   increment the count.
 * - Remove the last digit using integer division (/ 10).
 *
 * Time Complexity: O(d)
 *   where d is the number of digits in n.
 *
 * Space Complexity: O(1)
 */

class Solution {
    static int evenlyDivides(int n) {
        int number = n;
        int count = 0;

        while (number != 0) {
            int digit = number % 10;

            if (digit != 0 && n % digit == 0) {
                count++;
            }

            number /= 10;
        }

        return count;
    }
}
